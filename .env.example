# --- Database (Postgres / Supabase) ---
# ВАЖНО: За Netlify/Vercel serverless НЕ ползвай direct connection (db.xxx.supabase.co:5432).
# Той е IPv6-only на free tier и НЕ работи в serverless functions.
#
# DATABASE_URL → Supavisor TRANSACTION mode (port 6543) — за runtime (Prisma Client).
# DIRECT_URL   → Supavisor SESSION mode (port 5432) — за миграции (prisma db push / migrate).
#
# Формат:
# DATABASE_URL: postgresql://postgres.<REF>:<PASS>@aws-0-<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# DIRECT_URL:   postgresql://postgres.<REF>:<PASS>@aws-0-<REGION>.pooler.supabase.com:5432/postgres
DATABASE_URL="postgresql://postgres.psxkzuirjuujzujafsca:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.psxkzuirjuujzujafsca:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# --- Session ---
# 32+ random chars. Генерирай с: openssl rand -base64 48
SESSION_PASSWORD="change-me-to-a-long-random-32+-character-string-please"

# --- Admin login (за /admin) ---
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="changeme"

# --- External payment (Linktree etc.) ---
# Единен линк където клиентите купуват (Linktree, Payhip, Gumroad, Revolut...)
# Ако е празно, "купи" бутонът показва "Очаквай скоро"
LINKTREE_URL=""

# --- Site URL ---
# Local: http://localhost:3000
# Prod: https://your-domain.vercel.app или https://ivon.bg
SITE_URL="http://localhost:3000"

# --- Email (Resend) ---
# Свали ключ от https://resend.com/api-keys
# Ако е празно, имейлите се логват в конзолата (dev mode)
RESEND_API_KEY=""
# Default: onboarding@resend.dev (работи за всеки domain в Resend dev mode)
EMAIL_FROM="onboarding@resend.dev"
