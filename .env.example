# --- Database (Postgres) ---
# Local dev: ползвай Neon dev branch или локален Postgres (вж. DEPLOY.md)
# Prod (Vercel): копирай "Pooled connection" URL-а от Neon dashboard
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Session ---
# 32+ random chars. Генерирай с: openssl rand -base64 48
SESSION_PASSWORD="change-me-to-a-long-random-32+-character-string-please"

# --- Admin login (за /admin) ---
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="changeme"

# --- Stripe ---
# Test keys: https://dashboard.stripe.com/test/apikeys
# Live keys (само в prod): https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
# Webhook secret от https://dashboard.stripe.com/webhooks (Reveal signing secret)
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- Site URL (за Stripe redirect-и) ---
# Local: http://localhost:3000
# Prod: https://your-domain.vercel.app или https://ivon.bg
SITE_URL="http://localhost:3000"

# --- Email (Resend) ---
# Свали ключ от https://resend.com/api-keys
# Ако е празно, имейлите се логват в конзолата (dev mode)
RESEND_API_KEY=""
# Default: onboarding@resend.dev (работи за всеки domain в Resend dev mode)
EMAIL_FROM="onboarding@resend.dev"
