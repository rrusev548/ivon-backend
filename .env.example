# --- Database (Postgres / Supabase) ---
# ВАЖНО: За Netlify/Vercel serverless ползвай ПУЛЕРА (port 6543), НЕ direct connection.
# Direct connection (db.xxx.supabase.co:5432) е IPv6-only на free tier и НЕ работи в Netlify Functions.
#
# Supabase pooler (transaction mode) формат:
# postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://postgres.psxkzuirjuujzujafsca:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# --- Session ---
# 32+ random chars. Генерирай с: openssl rand -base64 48
SESSION_PASSWORD="change-me-to-a-long-random-32+-character-string-please"

# --- Admin login (за /admin) ---
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="changeme"

# --- Stripe ---
# Test keys: https://dashboard.stripe.com/test/apikeys
# Live keys (само в prod): https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
# Webhook secret от https://dashboard.stripe.com/webhooks (Reveal signing secret)
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- Site URL (за Stripe redirect-и) ---
# Local: http://localhost:3000
# Prod: https://your-domain.vercel.app или https://ivon.bg
SITE_URL="http://localhost:3000"
